---
// src/components/blog/GitHubCta.astro
interface Props {
  title?: string;
}
const { title = "Take Control of Your Affiliate Data" } = Astro.props;
const repoUrl = "https://github.com/ZAK123DSFDF/refearnapp";
const cloudUrl = "https://refearnapp.com/#pricing";
---

<div class="my-8 rounded-2xl border border-slate-200 bg-slate-50/50 p-6 sm:p-8">
  <h3 class="text-xl font-bold tracking-tight text-slate-900 m-0 mb-3">
    {title}
  </h3>

  <p class="text-sm text-slate-600 m-0 mb-6 leading-relaxed">
    RefearnApp is fully open-source, self-hostable, and AGPL-3.0 licensed. You can deploy it completely free on your own infrastructure using Coolify or follow our step-by-step setup walkthrough.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {/* Self-Hosted Column */}
    <div class="flex flex-col p-4 bg-white rounded-xl border border-slate-200 shadow-sm">
      <span class="text-xs font-bold uppercase tracking-wider text-indigo-600 mb-1">Developer Choice</span>
      <h4 class="text-base font-bold text-slate-900 m-0 mb-2">Self-Hosted Open Source</h4>
      <p class="text-xs text-slate-500 m-0 mb-4 flex-grow">Deploy directly on your own VPS via Coolify. Enjoy 100% data ownership.</p>

      <div class="flex flex-col gap-2 mt-auto">
        <a
          href="/docs"
          class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-xs font-bold text-white transition-colors hover:bg-indigo-500 text-center no-underline"
        >
          Read Deployment Docs →
        </a>
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-2 text-xs font-bold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 hover:text-indigo-600 no-underline"
        >
          ⭐ Star on GitHub
        </a>
      </div>
    </div>

    {/* Managed Cloud Column */}
    <div class="flex flex-col p-4 bg-white rounded-xl border border-indigo-100 shadow-sm ring-1 ring-indigo-500/5">
      <span class="text-xs font-bold uppercase tracking-wider text-emerald-600 mb-1">Production Ready</span>
      <h4 class="text-base font-bold text-slate-900 m-0 mb-2">Managed RefearnApp Cloud</h4>
      <p class="text-xs text-slate-500 m-0 mb-4 flex-grow">Get up and running instantly. Skip the manual environment configuration, provisioning, and setup tasks with a fully turnkey, zero-config deployment.</p>
      <a
        href={cloudUrl}
        class="inline-flex items-center justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-xs font-bold text-white transition-colors hover:bg-slate-800 text-center no-underline mt-auto"
      >
        Try Managed Cloud
      </a>
    </div>
  </div>
</div>