---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { competitors } from '../../data/competitors';
---

<Layout
  title="Affiliate Software Alternatives — Compare RefearnApp vs Rewardful, FirstPromoter, Tolt & More"
  description="Comparing affiliate tracking tools? See how RefearnApp stacks up against Rewardful, FirstPromoter, Tolt, PartnerStack and every major affiliate platform."
>
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-12 md:px-6 md:py-24">

    <div class="mt-8 mb-16 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-slate-100 border border-slate-200 px-4 py-1.5 text-sm font-semibold text-slate-700">
        🔍 Compare · Switch · Own Your Stack
      </div>
      <h1 class="mt-4 mb-6 text-4xl font-extrabold tracking-tight text-slate-900 md:text-6xl">
        RefearnApp<br />
        <span class="text-primary">Alternatives & Comparisons</span>
      </h1>
      <p class="mx-auto max-w-2xl text-xl leading-relaxed text-slate-600">
        See exactly how RefearnApp compares to the affiliate tracking tool you're using today —
        pricing, features, data ownership and more.
      </p>
    </div>

    <!-- Quick links to other angle indexes -->
    <div class="mb-16 grid gap-4 sm:grid-cols-3">
      <a href="/one-time-alternative" class="rounded-2xl border border-green-200 bg-green-50 p-5 text-center hover:shadow-md transition-all">
        <div class="text-3xl mb-2">💰</div>
        <h3 class="font-bold text-green-700 text-sm">One-Time Payment</h3>
        <p class="text-xs text-slate-500 mt-1">Pay once, own forever</p>
      </a>
      <a href="/open-source-alternative" class="rounded-2xl border border-indigo-200 bg-indigo-50 p-5 text-center hover:shadow-md transition-all">
        <div class="text-3xl mb-2">🔓</div>
        <h3 class="font-bold text-indigo-700 text-sm">Open Source</h3>
        <p class="text-xs text-slate-500 mt-1">Inspect & self-host the code</p>
      </a>
      <a href="/self-hosted-alternative" class="rounded-2xl border border-purple-200 bg-purple-50 p-5 text-center hover:shadow-md transition-all">
        <div class="text-3xl mb-2">🖥️</div>
        <h3 class="font-bold text-purple-700 text-sm">Self-Hosted</h3>
        <p class="text-xs text-slate-500 mt-1">Run it on your own server</p>
      </a>
    </div>

    <!-- All competitor cards -->
    <div class="mb-20">
      <h2 class="mb-8 text-center text-2xl font-bold text-slate-900">
        Compare RefearnApp To Every Major Affiliate Tool
      </h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {competitors.map((c) => (
          <a
            href={`/alternative/${c.slug}`}
            class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-slate-400 hover:shadow-md transition-all"
          >
            <div class="mb-3 flex flex-col gap-2">
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-bold text-slate-900 group-hover:text-primary transition-colors leading-tight">
                  {c.name} Alternative
                </h3>
                <span class="flex-shrink-0 rounded-full bg-red-50 px-2 py-0.5 text-xs font-semibold text-red-500 whitespace-nowrap self-start">
                  {c.price}
                </span>
              </div>
            </div>
            <p class="mb-4 text-sm text-slate-500">
              {c.weakness}
            </p>
            <div class="rounded-lg bg-slate-50 border border-slate-100 px-3 py-2 text-center">
              <span class="text-sm font-bold text-primary">Compare with RefearnApp →</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="rounded-3xl bg-gradient-to-br from-indigo-600 to-indigo-800 p-10 text-center shadow-2xl">
      <h2 class="mb-4 text-3xl font-extrabold text-white">Ready to Switch?</h2>
      <p class="mb-8 text-indigo-200 text-lg">
        Open source, self-hostable, one-time payment available. Built for founders who want control.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/#pricing" class="rounded-xl bg-white px-8 py-4 text-lg font-bold text-indigo-700 hover:bg-indigo-50 transition-colors shadow-lg">
          Get Started — $199 Lifetime
        </a>
        <a href="https://github.com/ZAK123DSFDF/refearnapp" target="_blank" rel="noopener noreferrer"
           class="rounded-xl border border-indigo-400 px-8 py-4 text-lg font-semibold text-white hover:bg-indigo-700 transition-colors">
          ⭐ View on GitHub
        </a>
      </div>
    </div>

  </main>
  <Footer />
</Layout>