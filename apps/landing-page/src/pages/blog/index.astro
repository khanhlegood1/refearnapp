---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/blog/BlogCard';
import { getLocalBlogPosts } from '../../utils/blog'; // 👈 Import our clean fetcher

const CDN_URL = 'https://assets.refearnapp.com';

// Fetch directly through Vite
const allPosts = await getLocalBlogPosts();

const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
};
---

<Layout
  title="Blog | RefearnApp - SaaS Affiliate Strategy"
  description="Guides, updates, and expert insights on building high-growth affiliate programs."
>
  <Header />

  <main class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <header class="mb-20 flex flex-col items-center text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 md:text-6xl">
        RefearnApp Insights
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-600">
        Everything you need to know about scaling your SaaS through referral marketing, affiliate tracking, and automated commissions.
      </p>
    </header>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-3">
      {
        allPosts.map((post) => (
          <BlogCard
            client:load
            title={post.data.title}
            date={formatDate(post.data.date)}
            slug={post.id}
            image={post.data.image}
            cdnUrl={CDN_URL}
          />
        ))
      }
    </div>
  </main>

  <Footer />
</Layout>