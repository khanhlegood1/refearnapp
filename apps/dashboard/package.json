{
  "name": "@repo/dashboard",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:tracker-dev": "cross-env NODE_ENV=development rollup -c",
    "build:tracker-prod": "cross-env NODE_ENV=production rollup -c",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "dotenv -e .env.nextjs -- drizzle-kit migrate",
    "db:reset": "bun src/db/reset.ts npx drizzle-kit generate && npx drizzle-kit migrate && bun src/db/currencySeed.ts && bun src/db/seeds/seedFun1.ts",
    "db:seed": "bun src/db/seeds/seedFun1.ts",
    "plan:upgrade": "bun src/db/userPlanSeed.ts",
    "db:database:reset": "bun src/db/self-hosted-reset.ts",
    "simulate": "bun src/db/subscriptionCycle.ts",
    "db:setup": "bun src/scripts/setup-db.js",
    "db:sync": "pnpm exec drizzle-kit generate && pnpm exec drizzle-kit migrate",
    "db:init-data": "bun src/db/seedSystem.ts && bun src/db/currencySeed.ts",
    "simulate:cancel": "bun src/db/subscriptionCancel.ts",
    "simulate:create:expire": "bun src/db/subscriptionCreateAndExpire.ts",
    "simulate:expire": "bun src/db/subscriptionExpire.ts",
    "generate:seeds": "bun src/db/seeds/generateSeeds.ts && bun src/db/reset.ts && npx drizzle-kit generate && npx drizzle-kit migrate && bun src/db/currencySeed.ts && bun src/db/seeds/seedFun.ts"
  },
