{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ],
      "env": [
        "DEBUG_SECRET",
        "INTERNAL_SECRET",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "R2_ACCESS_URL",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_PADDLE_PRICE_SUB_PRO_MONTHLY_PRODUCTION",
        "NEXT_PUBLIC_PADDLE_PRICE_SUB_ULTIMATE_MONTHLY_PRODUCTION",
        "NEXT_PUBLIC_PADDLE_PRICE_SUB_PRO_YEARLY_PRODUCTION",
        "NEXT_PUBLIC_PADDLE_PRICE_BUY_PRO_PRODUCTION",
        "NEXT_PUBLIC_PADDLE_PRICE_BUY_ULTIMATE_PRODUCTION",
        "NEXT_PUBLIC_PADDLE_PRICE_BUY_ULTIMATE_UPGRADE_PRODUCTION",
        "NEXT_PUBLIC_PADDLE_CLIENT_TOKEN_PRODUCTION",
        "NEXT_PUBLIC_PADDLE_CUSTOMER_PORTAL_PRODUCTION",
        "PADDLE_WEBHOOK_SECRET_PRODUCTION",
        "PADDLE_SECRET_TOKEN_PRODUCTION",
        "VERCEL_API_TOKEN",
        "VERCEL_PROJECT_ID",
        "DATABASE_URL",
        "ZEPTO_TOKEN",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_REDIRECT_URI",
        "EMAIL_VERIFICATION_CALLBACK_URL",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_ENDPOINT",
        "R2_TOKEN_VALUE",
        "R2_BUCKET_NAME",
        "BLOB_READ_WRITE_TOKEN",
        "KV_URL",
        "KV_REST_API_READ_ONLY_TOKEN",
        "REDIS_URL",
        "KV_REST_API_TOKEN",
        "KV_REST_API_URL",
        "DATABASE_URL",
        "STRIPE_CLIENT_ID",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_PAYPAL_CLIENT_ID",
        "PAYPAL_SECRET",
        "PADDLE_WEBHOOK_PUBLIC_KEY",
        "LEMON_SQUEEZY_WEBHOOK_SECRET",
        "SECRET_KEY",
        "CURRENCY_API_KEY",
        "NEXT_PUBLIC_RESERVED_SUBDOMAINS",
        "NEXT_PUBLIC_SELF_HOSTED",
        "NEXT_PUBLIC_REDIRECTION_URL",
        "QSTASH_TOKEN",
        "DISCORD_BOT_TOKEN",
        "DISCORD_GUILD_ID",
        "DISCORD_ULTIMATE_ROLE_ID",
        "DISCORD_PRO_ROLE_ID",
        "DISCORD_CLIENT_ID",
        "DISCORD_CLIENT_SECRET",
        "POLAR_ORGANIZATION_ID",
        "POLAR_ACCESS_TOKEN_PRODUCTION",
        "POLAR_PRO_PRODUCT_ID_PRODUCTION",
        "POLAR_ULTIMATE_PRODUCT_ID_PRODUCTION",
        "POLAR_ULTIMATE_UPGRADE_PRODUCT_ID_PRODUCTION",
        "APPSUMO_API_KEY"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}